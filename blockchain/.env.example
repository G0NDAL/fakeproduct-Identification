# ============================================================
# STEP 1 — Paste your MetaMask private key here
# MetaMask → 3 dots → Account Details → Export Private Key
# ============================================================
PRIVATE_KEY=

# ============================================================
# STEP 2 — Paste your Alchemy (or Infura) Sepolia RPC URL here
# Sign up free at https://alchemy.com → Create App → Sepolia
# Copy the HTTPS URL and paste below
# ============================================================
SEPOLIA_RPC_URL=

# ============================================================
# STEP 3 — (Optional) Etherscan API key for contract verification
# Get free at https://etherscan.io/myapikey
# ============================================================
ETHERSCAN_API_KEY=

# ============================================================
# STEP 4 — After running "npm run deploy", paste the printed
# contract addresses here AND also in the frontend .env file
# ============================================================
PRODUCT_REGISTRY_ADDRESS=
SELLER_REGISTRY_ADDRESS=
SUPPLY_CHAIN_ADDRESS=
